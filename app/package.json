    "gen": "vite build",
    "gen:prisma": "VIKE_DATA_ORM=prisma vite build",
    "gen:drizzle": "VIKE_DATA_ORM=drizzle vite build",
    "gen:native": "VIKE_DATA_ORM=native vite build",
    "gen:check": "VIKE_DATA_GEN=check vite build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vike-data/vike-schema": "workspace:*",
    "vike-auth": "workspace:*",
    "vike-teams": "workspace:*",
