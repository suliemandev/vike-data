{
  "name": "vike-storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "File storage / uploads: a swappable storage port (put/get/delete/url, in-memory in dev, S3/R2/disk in prod), an `uploads` metadata table, and a multipart upload endpoint bound to the signed-in user. Stateful like vike-push; the per-framework upload control + the vike-admin file widget land next.",
  "exports": {
    ".": "./index.js",
    "./config": "./+config.js",
    "./schema": "./schema.js",
    "./middleware": "./middleware.js",
    "./client": "./client.js",
    "./react/FileUpload": "./react/FileUpload.jsx",
    "./react/FileField": "./react/FileField.jsx",
    "./react/AdminFileRegister": "./react/AdminFileRegister.jsx",
    "./react-admin": "./react-admin/+config.js",
    "./vue/FileUpload": "./vue/FileUpload.vue"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@universal-orm/core": "workspace:*",
    "@vike-data/kit": "workspace:*",
    "@vike-data/vike-schema": "workspace:*",
    "vike-auth": "workspace:*"
  },
  "devDependencies": {
    "@universal-orm/memory": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike-react": ">=0.6",
    "vue": ">=3",
    "vike-vue": ">=0.9",
    "vike-admin": "workspace:*"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vike-react": { "optional": true },
    "vue": { "optional": true },
    "vike-vue": { "optional": true },
    "vike-admin": { "optional": true }
  }
}
