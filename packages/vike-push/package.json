    "vike-auth": "workspace:*",
    "vike-queue": "workspace:*"
  },
  "devDependencies": {
    "@universal-orm/memory": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike-react": ">=0.6",
    "vue": ">=3",
    "vike-vue": ">=0.9"
  },
