    "./vue/PushToggle": "./vue/PushToggle.vue"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@universal-orm/core": "workspace:*",
