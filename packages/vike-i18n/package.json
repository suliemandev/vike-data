{
  "name": "vike-i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Localization extension: a framework-agnostic core (a cumulative `messages` contribution point + `locale`, on top of Vike's locale routing) plus per-framework bindings as subpaths (vike-i18n/react, and vue/solid later). One package, install and import the subpath for your framework.",
  "exports": {
    ".": "./index.js",
    "./config": "./+config.js",
    "./plugin": "./plugin.js",
    "./oncreate": "./oncreate.js",
    "./texts": "./texts.js",
    "./translate": "./translate.js",
    "./translator": "./translator.js",
    "./cli": "./cli.js",
    "./react": "./react/+config.js",
    "./react/hooks": "./react/context.js",
    "./react/html": "./react/html.js",
    "./react/LocaleWrapper": "./react/LocaleWrapper.jsx"
  },
  "bin": {
    "vike-translate": "./bin/vike-translate.js"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike": "^0.4.0",
    "vike-react": ">=0.6",
    "react-dom": ">=18",
    "@anthropic-ai/sdk": ">=0.30"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vike-react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "scripts": {
    "test": "node --test"
  }
}
