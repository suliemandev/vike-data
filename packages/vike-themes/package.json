{
  "name": "vike-themes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Theme extension: a framework-agnostic core (design tokens -> CSS variables; theme brand + appearance axes) plus per-framework bindings as subpaths (vike-themes/react, and vue/solid later). One package, install and import the subpath for your framework.",
  "dependencies": {
    "chroma-js": "^3.2.0"
  },
  "exports": {
    ".": "./index.js",
    "./config": "./+config.js",
    "./oncreate": "./oncreate.js",
    "./react": "./react/+config.js",
    "./react/hooks": "./react/context.js",
    "./react/ThemeWrapper": "./react/ThemeWrapper.jsx",
    "./vue": "./vue/+config.js",
    "./vue/ThemeWrapper": "./vue/ThemeWrapper.vue"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike-react": ">=0.6",
    "react-dom": ">=18",
    "vue": ">=3",
    "vike-vue": ">=0.9"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vike-react": { "optional": true },
    "react-dom": { "optional": true },
    "vue": { "optional": true },
    "vike-vue": { "optional": true }
  },
  "scripts": {
    "test": "node --test"
  }
}
