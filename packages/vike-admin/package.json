{
  "name": "vike-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "vike-admin: a working admin panel on install. Ships /admin/* pages that list and create the rows of every table your extensions composed, gated by auth, themed, localized. Writes no ORM code: the composed schema is the intent, the admin UI is derived, the resource is the refinement.",
  "exports": {
    "./config": "./+config.js",
    "./define": "./define.js",
    "./resolve": "./resolve.js",
    "./data": "./data.js",
    "./guard": "./guard.js",
    "./api": "./api.js",
    "./query": "./query.js",
    "./react": "./react/+config.js",
    "./react/widgets": "./react/widgets.jsx",
    "./react/widget-registry": "./react/widget-registry.js",
    "./react/DashboardPage": "./react/DashboardPage.jsx",
    "./react/ListPage": "./react/ListPage.jsx",
    "./react/NewPage": "./react/NewPage.jsx",
    "./react/EditPage": "./react/EditPage.jsx",
    "./vue": "./vue/+config.js",
    "./vue/DashboardPage": "./vue/DashboardPage.vue",
    "./vue/ListPage": "./vue/ListPage.vue",
    "./vue/NewPage": "./vue/NewPage.vue",
    "./vue/EditPage": "./vue/EditPage.vue"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@universal-orm/core": "workspace:*",
    "@universal-orm/memory": "workspace:*",
    "@vike-data/kit": "workspace:*",
    "@vike-data/vike-schema": "workspace:*",
    "vike-view": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike": "*",
    "vike-react": ">=0.6",
    "vue": ">=3",
    "vike-vue": ">=0.9"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vike-react": { "optional": true },
    "vue": { "optional": true },
    "vike-vue": { "optional": true }
  }
}
