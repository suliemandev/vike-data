{
  "name": "vike-notifications",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-channel notifications: notify(user, notification) fans one intent out to email + push + an in-app feed over vike-queue, with a runtime channel registry, an owned notifications table, session-scoped feed endpoints, and a per-framework bell. The director layer over the channels.",
  "exports": {
    ".": "./index.js",
    "./config": "./+config.js",
    "./schema": "./schema.js",
    "./middleware": "./middleware.js",
    "./client": "./client.js",
    "./react/Bell": "./react/Bell.jsx",
    "./vue/Bell": "./vue/Bell.vue"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@universal-orm/core": "workspace:*",
    "@vike-data/vike-schema": "workspace:*",
    "vike-auth": "workspace:*",
    "vike-queue": "workspace:*"
  },
  "devDependencies": {
    "@universal-orm/memory": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike-react": ">=0.6",
    "vue": ">=3",
    "vike-vue": ">=0.9"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vike-react": { "optional": true },
    "vue": { "optional": true },
    "vike-vue": { "optional": true }
  }
}
