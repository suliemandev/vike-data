{
  "name": "vike-stripe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Stripe billing extension: one package, multiple billing models as subpath implementations (subscription / purchase). Each picks WHO you bill via the `segment` option ('b2b' | 'b2c') and writes through universal-orm (no ORM import); the shared Stripe SDK lives at the root. Stripe is the baked-in default provider; other providers come later as their own package (vike-paddle).",
  "exports": {
    "./stripe": "./stripe.js",
    "./subscription": "./subscription/+config.js",
    "./subscription/schemas": "./subscription/schemas.js",
    "./subscription/middleware": "./subscription/vike-middleware.js",
    "./subscription/events": "./subscription/events.js",
    "./purchase": "./purchase/+config.js",
    "./purchase/schemas": "./purchase/schemas.js",
    "./purchase/middleware": "./purchase/vike-middleware.js"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@universal-orm/core": "workspace:*",
    "@universal-orm/memory": "workspace:*",
    "@vike-data/universal-schema": "workspace:*",
    "@vike-data/vike-schema": "workspace:*",
    "vike-auth": "workspace:*",
    "vike-teams": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@rudderjs/database": "^1.5.5",
    "@universal-orm/drizzle": "workspace:*",
    "@universal-orm/rudder": "workspace:*",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2"
  }
}
