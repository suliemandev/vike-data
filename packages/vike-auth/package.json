{
  "name": "vike-auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Auth extension: a framework-agnostic core (owns users + sessions + login_tokens and a magic-link server tier via universal middleware, ORM-agnostic) plus a React binding as a subpath (vike-auth/react), which ships its own /login + /account pages. One package; install and import the subpath for your framework.",
  "exports": {
    ".": "./index.js",
    "./config": "./+config.js",
    "./middleware": "./vike-middleware.js",
    "./onCreatePageContext": "./oncreate.js",
    "./react": "./react/+config.js",
    "./react/hooks": "./react/useUser.js",
    "./react/SignInForm": "./react/SignInForm.jsx",
    "./react/UserButton": "./react/UserButton.jsx",
    "./react/LoginPage": "./react/LoginPage.jsx",
    "./react/AccountPage": "./react/AccountPage.jsx",
    "./react/messages": "./react/messages.js",
    "./fr": "./fr/+config.js",
    "./ar": "./ar/+config.js"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@vike-data/vike-schema": "workspace:*",
    "vike-i18n": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vike-react": ">=0.6"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vike-react": { "optional": true }
  }
}
