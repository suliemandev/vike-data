  "scripts": {
    "dev": "tsx server/index.ts"
  },
  "dependencies": {
    "@universal-orm/core": "workspace:*",
    "@universal-orm/memory": "workspace:*",
    "@vike-data/universal-schema": "workspace:*",
    "@vike-data/vike-schema": "workspace:*",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vike": "^0.4.260",
    "vike-ai": "workspace:*",
    "vike-auth": "workspace:*",
    "vike-react": "^0.6.25"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vite": "^7.3.6"
  }
}
