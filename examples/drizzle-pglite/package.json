{
  "name": "app-drizzle-pglite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The real persistent-DB twin of examples/react: the same admin + auth + rbac app, but on vike-drizzle + an embedded Postgres (pglite) instead of the in-memory adapter. Shows the real seeding story: tables come from migrations, reference data is seeded idempotently, business rows are a separate step (or real signups) -- never a raw insert on boot.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.js",
    "db:seed": "tsx db/seed.js",
    "db:reset": "node -e \"import('node:fs').then(fs=>fs.rmSync(new URL('.pgdata',import.meta.url),{recursive:true,force:true}))\"",
    "setup": "pnpm db:migrate && pnpm db:seed",
    "test": "node --test"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@universal-orm/core": "workspace:*",
    "@universal-orm/drizzle": "workspace:*",
    "@vike-data/vike-schema": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vike": "^0.4.0",
    "vike-react": "^0.6.0",
    "vike-admin": "workspace:*",
    "vike-auth": "workspace:*",
    "vike-drizzle": "workspace:*",
    "vike-i18n": "workspace:*",
    "vike-layouts": "workspace:*",
    "vike-rbac": "workspace:*",
    "vike-theme-emerald": "workspace:*",
    "vike-themes": "workspace:*",
    "vite": "^7.1.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.2"
  }
}
