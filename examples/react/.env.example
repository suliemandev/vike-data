# Optional production transports for the demo. With none of these set the app runs on the
# dev console/outbox transports (zero config). Copy to `.env` and fill in to deliver for real.
# +onCreateGlobalContext.js reads them once per server.

# Mail (Resend) - magic-link and notification email.
# Get a key at https://resend.com. RESEND_FROM must be a Resend-verified sender; the
# default below is Resend's shared test sender (only delivers to the account owner).
RESEND_API_KEY=
RESEND_FROM=Vike Data Demo <onboarding@resend.dev>

# Web Push (VAPID) - real browser push. Generate a P-256 keypair with
# `npx web-push generate-vapid-keys`. The public key must match the private key AND is what
# the client subscribes with; set both or neither (only-private is ignored).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:demo@example.com
